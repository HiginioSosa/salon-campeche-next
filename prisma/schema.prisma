generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Reserva {
  id                 String    @id @default(cuid())
  fecha              String    // 'YYYY-MM-DD'
  estado             String    // ver src/lib/reservas/estados.ts (EstadoReserva)
  espacio            String? // 'PRIMER_PISO' | 'AMBOS_PISOS'
  clienteNombre      String
  clienteTelefono    String
  clienteEmail       String?
  tipoEvento         String
  numInvitados       Int?
  mensajeCliente     String?
  notasInternas      String?
  anticipoMonto      Int?
  anticipoRecibidoEn DateTime?
  solicitadaEn       DateTime?
  autorizadaEn       DateTime?
  expiraEn           DateTime?
  confirmadaEn       DateTime?
  creadaEn           DateTime  @default(now())
  actualizadaEn      DateTime  @updatedAt

  @@index([fecha])
  @@index([estado])
  // NOTA: existe además un índice ÚNICO PARCIAL `reserva_fecha_activa_unica` sobre
  // `fecha` (solo para estados activos) que impide dos reservas activas en la misma
  // fecha. Prisma no puede expresar índices parciales en el schema, así que vive en
  // la migración SQL (prisma/migrations/*_init_reservas/migration.sql). No borrarlo.
}

model UsuarioAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  creadaEn     DateTime @default(now())
}
